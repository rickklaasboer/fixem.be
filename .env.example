# Server
PORT=3000
PUBLIC_BASE_URL=https://fixem.be

# Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=14400
RESOLVE_TIMEOUT_MS=5000

# Rate limiting (per client IP per minute, crawlers exempt)
RATE_LIMIT_PER_MIN=60

# Extra crawler user-agent substrings (comma-separated, optional)
EXTRA_CRAWLER_UAS=

# Twitch (enables clip embeds — register an app at https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Twitch GraphQL — pinned public web constants (override only when Twitch rotates them)
TWITCH_GQL_CLIENT_ID=
TWITCH_GQL_CLIP_HASH=

# Twitter/X — pinned syndication feature flags (override only if X changes the required flags)
TWITTER_SYNDICATION_FEATURES=

# Reddit (optional — anonymous JSON is IP-blocked on many networks)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional offload for the anonymous old.reddit scrape. Reddit's edge 403-blocks
# many datacenter IP ranges (Hetzner etc.); set this to a proxy prefix that the
# target URL is appended to (URL-encoded), e.g. https://proxy.example/fetch?u=
# — same scheme as INSTAGRAM_PROXY_URL. Blank = direct fetch. Never used on the
# OAuth path.
REDDIT_PROXY_URL=
# Alternative offload: a standard HTTP CONNECT proxy (per-GB residential
# providers like DataImpulse), e.g. http://user:pass@gw.dataimpulse.com:823 —
# applied via Bun's fetch `proxy` option on the same anonymous fetches. Blank =
# direct fetch. Never used on the OAuth path.
REDDIT_HTTP_PROXY=

# Video proxy — enables inline video for TikTok/Threads/Instagram.
# Set PROXY_SECRET to a random string (e.g. `openssl rand -hex 32`) to turn on
# the signed /v/ media proxy; leave it blank and inline video degrades to a
# thumbnail or link. CRITICAL: serve /v/ (or a v.fixem.be) from a DNS-only
# "grey-cloud" record — NEVER proxy video through Cloudflare's orange cloud
# (Cloudflare ToS 2.8 forbids proxying non-HTML media in bulk).
PROXY_SECRET=
# Comma-separated CDN hosts the proxy may fetch (suffix match). Blank uses the
# built-in default allowlist in src/config/Config.ts.
PROXY_HOST_ALLOWLIST=
# Max simultaneous in-flight proxied streams (default 32).
PROXY_MAX_CONCURRENT=
# Max bytes streamed per proxied response (default 104857600 = 100 MiB).
PROXY_MAX_BYTES=
# Upstream fetch timeout for the proxy, ms (default 10000).
PROXY_TIMEOUT_MS=

# Threads — pinned public web-client constants (override only when Meta rotates
# them; defaults live in src/config/defaults.ts).
THREADS_LSD=
THREADS_DOC_ID=
THREADS_APP_ID=
THREADS_FRIENDLY_NAME=

# TikTok — pinned public web-client constants (override only when TikTok rotates
# them; defaults live in src/config/defaults.ts).
TIKTOK_REHYDRATION_SCRIPT_ID=
TIKTOK_MOBILE_API_HOST=
TIKTOK_IID=
TIKTOK_DEVICE_ID=

# Instagram — pinned public web-client constants (override only when Meta rotates
# them; defaults live in src/config/defaults.ts).
INSTAGRAM_DOC_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_FRIENDLY_NAME=
# Optional residential-proxy offload. Instagram is usually blocked from
# datacenter IPs (login wall); set this to a proxy prefix that the target URL is
# appended to (URL-encoded) to improve reliability. Blank = direct fetch.
INSTAGRAM_PROXY_URL=
# Optional logged-in session cookie to walk past the login wall (use a BURNER
# account — Instagram bans scraping accounts). Copy from a browser: DevTools →
# Application → Cookies → instagram.com. Minimum `sessionid=...`; include
# `csrftoken=...; ds_user_id=...` too for fewer challenges. This is a full
# account credential: keep it secret, expect it to expire/get banned (rotate).
INSTAGRAM_COOKIE=
# Opt-in last-resort fallback: when our own fetch is login-walled, resolve via
# snapsave.app. THIRD-PARTY & FRAGILE — depends on snapsave.app + its rapidcdn.app
# delivery CDN staying up and not changing their scheme; may break without notice.
# Set to "true" to enable. Off by default.
INSTAGRAM_SNAPSAVE=

# --- Public API v1 (/api/v1/*) ---
# Comma-separated set of valid bearer keys for the public metadata API. Callers
# send `Authorization: Bearer <key>`; buckets are per-key. Generate each with
# `openssl rand -hex 32`. BLANK = the whole /api/v1 namespace is closed (404) —
# never open unauthenticated. The uptime monitor (Gatus) uses one of these keys
# too; STATUS_API_KEY was removed — API_KEYS subsumes it.
API_KEYS=
# Per-key requests/minute for /api/v1/* (distinct from the browser-facing
# RATE_LIMIT_PER_MIN above). Default 60.
API_RATE_LIMIT_PER_MIN=60
# Max URLs accepted by POST /api/v1/resolve (batch). Default 20.
BATCH_MAX_URLS=
# The single bearer key the Gatus monitor presents on its /api/v1/health checks.
# MUST be one of the keys listed in API_KEYS above (Gatus sends one token, not a
# set). E.g. API_KEYS=mon-abc,cust-def and MONITOR_API_KEY=mon-abc.
MONITOR_API_KEY=

# Status monitoring (Gatus) — only used by the `gatus` service in
# compose.prod.yaml. Discord webhook Gatus posts to on adapter failure/recovery.
# Blank = dashboard only, no alerts. Create one in a Discord channel under
# Integrations → Webhooks.
GATUS_DISCORD_WEBHOOK_URL=

# --- Usage metrics (bun:sqlite) ---
# Path to the durable usage-rollup SQLite file (WAL). Its parent dir is created
# if missing. Blank = default. Use ":memory:" to disable durability (tests only).
USAGE_DB_PATH=./data/usage.sqlite
# How often (ms) buffered counters flush to SQLite. Floor 1000. Default 10000.
USAGE_FLUSH_INTERVAL_MS=10000
# Comma-separated admin bearer keys for GET /api/v1/stats/* (global usage/
# bandwidth — NOT customer API_KEYS). Generate with `openssl rand -hex 32`.
# BLANK = the whole /api/v1/stats namespace is closed (404).
ADMIN_API_KEYS=
