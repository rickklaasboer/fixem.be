{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noEmit": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "paths": {"@/*": ["./src/*"]},
        "types": ["bun"],
        "skipLibCheck": true
    },
    "include": ["src", "tests"]
}
