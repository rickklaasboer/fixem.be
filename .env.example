# Server
PORT=3000
PUBLIC_BASE_URL=https://fixem.be

# Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=14400
RESOLVE_TIMEOUT_MS=5000

# Rate limiting (per client IP per minute, crawlers exempt)
RATE_LIMIT_PER_MIN=60

# Extra crawler user-agent substrings (comma-separated, optional)
EXTRA_CRAWLER_UAS=

# Twitch (enables clip embeds — register an app at https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Twitch GraphQL — pinned public web constants (override only when Twitch rotates them)
TWITCH_GQL_CLIENT_ID=
TWITCH_GQL_CLIP_HASH=

# Twitter/X — pinned syndication feature flags (override only if X changes the required flags)
TWITTER_SYNDICATION_FEATURES=

# Reddit (optional — anonymous JSON is IP-blocked on many networks)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Video proxy — enables inline video for TikTok/Threads/Instagram.
# Set PROXY_SECRET to a random string (e.g. `openssl rand -hex 32`) to turn on
# the signed /v/ media proxy; leave it blank and inline video degrades to a
# thumbnail or link. CRITICAL: serve /v/ (or a v.fixem.be) from a DNS-only
# "grey-cloud" record — NEVER proxy video through Cloudflare's orange cloud
# (Cloudflare ToS 2.8 forbids proxying non-HTML media in bulk).
PROXY_SECRET=
# Comma-separated CDN hosts the proxy may fetch (suffix match). Blank uses the
# built-in default allowlist in src/lib/config.ts.
PROXY_HOST_ALLOWLIST=
# Max simultaneous in-flight proxied streams (default 32).
PROXY_MAX_CONCURRENT=
# Max bytes streamed per proxied response (default 104857600 = 100 MiB).
PROXY_MAX_BYTES=
# Upstream fetch timeout for the proxy, ms (default 10000).
PROXY_TIMEOUT_MS=

# Threads — pinned public web-client constants (override only when Meta rotates
# them; defaults live in src/adapters/threads.ts).
THREADS_LSD=
THREADS_DOC_ID=
THREADS_APP_ID=
THREADS_FRIENDLY_NAME=

# TikTok — pinned public web-client constants (override only when TikTok rotates
# them; defaults live in src/adapters/tiktok.ts).
TIKTOK_MOBILE_API_HOST=
TIKTOK_IID=
TIKTOK_DEVICE_ID=

# Instagram — pinned public web-client constants (override only when Meta rotates
# them; defaults live in src/adapters/instagram.ts).
INSTAGRAM_DOC_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_FRIENDLY_NAME=
# Optional residential-proxy offload. Instagram is usually blocked from
# datacenter IPs (login wall); set this to a proxy prefix that the target URL is
# appended to (URL-encoded) to improve reliability. Blank = direct fetch.
INSTAGRAM_PROXY_URL=
